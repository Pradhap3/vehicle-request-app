// src/models/CabRequest.js
const { sql, getPool } = require('../config/database');
const logger = require('../utils/logger');
const { v4: uuidv4 } = require('uuid');

class CabRequest {
  static async findAll(filters = {}) {
    try {
      const pool = getPool();
      const request = pool.request();
      
      let whereConditions = ['1=1'];
      
      if (filters.status) {
        request.input('status', sql.NVarChar(50), filters.status);
        whereConditions.push('cr.status = @status');
      }
      if (filters.employee_id) {
        request.input('employee_id', sql.NVarChar(255), filters.employee_id);
        whereConditions.push('cr.employee_id = @employee_id');
      }
      if (filters.route_id) {
        request.input('route_id', sql.NVarChar(255), filters.route_id);
        whereConditions.push('cr.route_id = @route_id');
      }
      if (filters.cab_id) {
        request.input('cab_id', sql.NVarChar(255), filters.cab_id);
        whereConditions.push('cr.cab_id = @cab_id');
      }
      if (filters.date) {
        request.input('date', sql.Date, filters.date);
        whereConditions.push('CAST(cr.pickup_time AS DATE) = @date');
      }
      
      const result = await request.query(`
        SELECT cr.*, 
               CAST(cr.pickup_time AS DATE) as pickup_date,
               e.name as employee_name, e.email as employee_email, e.phone as employee_phone, e.department,
               c.cab_number, c.capacity as cab_capacity,
               d.name as driver_name, d.phone as driver_phone,
               r.name as route_name, r.start_point, r.end_point, r.estimated_time_minutes
        FROM cab_requests cr
        INNER JOIN users e ON cr.employee_id = e.id
        LEFT JOIN cabs c ON cr.cab_id = c.id
        LEFT JOIN users d ON c.driver_id = d.id
        LEFT JOIN routes r ON cr.route_id = r.id
        WHERE ${whereConditions.join(' AND ')}
        ORDER BY cr.pickup_time DESC
      `);
      
      return result.recordset;
    } catch (error) {
      logger.error('Error fetching cab requests:', error);
      throw error;
    }
  }

  static async findById(id) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('id', sql.NVarChar(255), id)
        .query(`
          SELECT cr.*, 
                 e.name as employee_name, e.email as employee_email, e.phone as employee_phone, e.department,
                 c.cab_number, c.capacity as cab_capacity,
                 d.name as driver_name, d.phone as driver_phone,
                 r.name as route_name, r.start_point, r.end_point
          FROM cab_requests cr
          INNER JOIN users e ON cr.employee_id = e.id
          LEFT JOIN cabs c ON cr.cab_id = c.id
          LEFT JOIN users d ON c.driver_id = d.id
          LEFT JOIN routes r ON cr.route_id = r.id
          WHERE cr.id = @id
        `);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error finding cab request by ID:', error);
      throw error;
    }
  }

  static async create(requestData) {
    try {
      const pool = getPool();
      const newId = uuidv4().toUpperCase();
      
      const result = await pool.request()
        .input('id', sql.NVarChar(255), newId)
        .input('employee_id', sql.NVarChar(255), requestData.employee_id)
        .input('route_id', sql.NVarChar(255), requestData.route_id || null)
        .input('pickup_time', sql.DateTime, requestData.pickup_time)
        .input('pickup_location', sql.NVarChar(500), requestData.pickup_location || null)
        .input('dropoff_location', sql.NVarChar(500), requestData.dropoff_location || null)
        .input('pickup_latitude', sql.Float, requestData.pickup_latitude || null)
        .input('pickup_longitude', sql.Float, requestData.pickup_longitude || null)
        .input('dropoff_latitude', sql.Float, requestData.dropoff_latitude || null)
        .input('dropoff_longitude', sql.Float, requestData.dropoff_longitude || null)
        .input('purpose', sql.NVarChar(500), requestData.purpose || null)
        .input('passengers', sql.Int, requestData.passengers || 1)
        .input('status', sql.NVarChar(50), 'PENDING')
        .input('priority', sql.NVarChar(20), requestData.priority || 'NORMAL')
        .input('notes', sql.NVarChar(1000), requestData.notes || null)
        .query(`
          INSERT INTO cab_requests (id, employee_id, route_id, pickup_time, pickup_location, dropoff_location,
                                   pickup_latitude, pickup_longitude, dropoff_latitude, dropoff_longitude,
                                   purpose, passengers, status, priority, notes, created_at, updated_at)
          OUTPUT INSERTED.*
          VALUES (@id, @employee_id, @route_id, @pickup_time, @pickup_location, @dropoff_location,
                  @pickup_latitude, @pickup_longitude, @dropoff_latitude, @dropoff_longitude,
                  @purpose, @passengers, @status, @priority, @notes, GETDATE(), GETDATE())
        `);
      
      logger.info(`Cab request created for employee ${requestData.employee_id}`);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error creating cab request:', error);
      throw error;
    }
  }

  static async update(id, requestData) {
    try {
      const pool = getPool();
      const request = pool.request().input('id', sql.NVarChar(255), id);
      
      const updates = [];
      
      if (requestData.cab_id !== undefined) {
        request.input('cab_id', sql.NVarChar(255), requestData.cab_id);
        updates.push('cab_id = @cab_id');
      }
      if (requestData.route_id) {
        request.input('route_id', sql.NVarChar(255), requestData.route_id);
        updates.push('route_id = @route_id');
      }
      if (requestData.pickup_time) {
        request.input('pickup_time', sql.DateTime, requestData.pickup_time);
        updates.push('pickup_time = @pickup_time');
      }
      if (requestData.status) {
        request.input('status', sql.NVarChar(50), requestData.status);
        updates.push('status = @status');
      }
      if (requestData.priority) {
        request.input('priority', sql.NVarChar(20), requestData.priority);
        updates.push('priority = @priority');
      }
      if (requestData.notes !== undefined) {
        request.input('notes', sql.NVarChar(1000), requestData.notes);
        updates.push('notes = @notes');
      }
      
      updates.push('updated_at = GETDATE()');
      
      const result = await request.query(`
        UPDATE cab_requests 
        SET ${updates.join(', ')}
        OUTPUT INSERTED.*
        WHERE id = @id
      `);
      
      return result.recordset[0];
    } catch (error) {
      logger.error('Error updating cab request:', error);
      throw error;
    }
  }

  static async delete(id) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('id', sql.NVarChar(255), id)
        .query(`DELETE FROM cab_requests OUTPUT DELETED.id WHERE id = @id`);
      
      if (result.recordset.length === 0) {
        throw new Error('Request not found');
      }
      
      return { success: true, id };
    } catch (error) {
      logger.error('Error deleting cab request:', error);
      throw error;
    }
  }

  static async assignCab(requestId, cabId) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('id', sql.NVarChar(255), requestId)
        .input('cab_id', sql.NVarChar(255), cabId)
        .query(`
          UPDATE cab_requests 
          SET cab_id = @cab_id, 
              status = 'APPROVED',
              assigned_at = GETDATE(),
              updated_at = GETDATE()
          OUTPUT INSERTED.*
          WHERE id = @id
        `);
      
      logger.info(`Cab ${cabId} assigned to request ${requestId}`);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error assigning cab:', error);
      throw error;
    }
  }

  static async cancel(requestId) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('id', sql.NVarChar(255), requestId)
        .query(`
          UPDATE cab_requests 
          SET status = 'CANCELLED', updated_at = GETDATE()
          OUTPUT INSERTED.*
          WHERE id = @id AND status IN ('PENDING', 'APPROVED')
        `);
      
      if (result.recordset.length === 0) {
        throw new Error('Cannot cancel this request');
      }
      
      return result.recordset[0];
    } catch (error) {
      logger.error('Error cancelling request:', error);
      throw error;
    }
  }

  static async getTodayStats() {
    try {
      const pool = getPool();
      const result = await pool.request()
        .query(`
          SELECT 
            COUNT(*) as total,
            SUM(CASE WHEN status = 'PENDING' THEN 1 ELSE 0 END) as pending,
            SUM(CASE WHEN status = 'APPROVED' THEN 1 ELSE 0 END) as approved,
            SUM(CASE WHEN status = 'COMPLETED' THEN 1 ELSE 0 END) as completed,
            SUM(CASE WHEN status = 'CANCELLED' THEN 1 ELSE 0 END) as cancelled
          FROM cab_requests
          WHERE CAST(pickup_time AS DATE) = CAST(GETDATE() AS DATE)
        `);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error getting today stats:', error);
      throw error;
    }
  }

  static async getPendingRequestsForRoute(routeId, date) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('route_id', sql.NVarChar(255), routeId)
        .input('date', sql.Date, date)
        .query(`
          SELECT cr.*, e.name as employee_name, e.phone as employee_phone
          FROM cab_requests cr
          INNER JOIN users e ON cr.employee_id = e.id
          WHERE cr.route_id = @route_id 
            AND CAST(cr.pickup_time AS DATE) = @date
            AND cr.status = 'PENDING'
          ORDER BY cr.pickup_time
        `);
      return result.recordset;
    } catch (error) {
      logger.error('Error getting pending requests for route:', error);
      throw error;
    }
  }
}

module.exports = CabRequest;