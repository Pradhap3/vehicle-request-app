# ================================
# DATABASE (Azure SQL)
# ================================
DB_HOST=your-server.database.windows.net
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

# ================================
# SERVER
# ================================
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.vercel.app
FRONTEND_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173
REQUEST_BODY_LIMIT=1mb

# ================================
# AUTH
# ================================
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRY=8h
REFRESH_TOKEN_EXPIRY=7d

# ================================
# EMAIL (optional, but recommended)
# ================================
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=your_email@company.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=your_email@company.com

# ================================
# APP FEATURES
# ================================
ENABLE_AI_FEATURES=true
BOOKING_MIN_ADVANCE_MINUTES=60
AUTO_ASSIGN_WINDOW_MINUTES=30
REQUEST_CONFLICT_WINDOW_MINUTES=180
REQUIRE_CALL_ATTEMPT_FOR_NO_SHOW=true
CALL_ATTEMPT_WINDOW_MINUTES=15

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ================================
# LOGGING
# ================================
LOG_LEVEL=info
# Office geofence for shift delay monitoring
OFFICE_LATITUDE=12.9716
OFFICE_LONGITUDE=77.5946
OFFICE_GEOFENCE_RADIUS_KM=1.0
SHIFT_DELAY_ALERT_COOLDOWN_MINUTES=30
