// src/models/Cab.js
const { sql, getPool } = require('../config/database');
const logger = require('../utils/logger');

class Cab {
  static async findAll() {
    try {
      const pool = getPool();
      const result = await pool.request()
        .query(`
          SELECT c.id, c.cab_number, c.capacity, c.driver_id, c.status,
                 c.current_latitude, c.current_longitude, c.last_location_update,
                 c.is_active, c.created_at, c.updated_at,
                 u.name as driver_name, u.phone as driver_phone, u.email as driver_email
          FROM cabs c
          LEFT JOIN users u ON c.driver_id = u.id
          WHERE c.is_active = 1
          ORDER BY c.cab_number
        `);
      return result.recordset;
    } catch (error) {
      logger.error('Error fetching cabs:', error);
      throw error;
    }
  }

  static async findById(id) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('id', sql.Int, id)
        .query(`
          SELECT c.*, u.name as driver_name, u.phone as driver_phone, u.email as driver_email
          FROM cabs c
          LEFT JOIN users u ON c.driver_id = u.id
          WHERE c.id = @id
        `);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error finding cab by ID:', error);
      throw error;
    }
  }

  static async findByDriverId(driverId) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('driver_id', sql.Int, driverId)
        .query(`
          SELECT * FROM cabs 
          WHERE driver_id = @driver_id AND is_active = 1
        `);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error finding cab by driver ID:', error);
      throw error;
    }
  }

  static async findAvailable(requiredCapacity = 1) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('capacity', sql.Int, requiredCapacity)
        .query(`
          SELECT c.*, u.name as driver_name, u.phone as driver_phone
          FROM cabs c
          INNER JOIN users u ON c.driver_id = u.id
          WHERE c.is_active = 1 
            AND c.status = 'AVAILABLE'
            AND c.capacity >= @capacity
            AND u.is_active = 1
          ORDER BY c.capacity ASC
        `);
      return result.recordset;
    } catch (error) {
      logger.error('Error finding available cabs:', error);
      throw error;
    }
  }

  static async create(cabData) {
    try {
      const pool = getPool();
      
      const result = await pool.request()
        .input('cab_number', sql.NVarChar(50), cabData.cab_number)
        .input('capacity', sql.Int, cabData.capacity)
        .input('driver_id', sql.Int, cabData.driver_id || null)
        .input('status', sql.NVarChar(20), 'AVAILABLE')
        .input('is_active', sql.Bit, 1)
        .query(`
          INSERT INTO cabs (cab_number, capacity, driver_id, status, is_active, created_at, updated_at)
          OUTPUT INSERTED.*
          VALUES (@cab_number, @capacity, @driver_id, @status, @is_active, GETDATE(), GETDATE())
        `);
      
      logger.info(`Cab created: ${cabData.cab_number}`);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error creating cab:', error);
      if (error.number === 2627) {
        throw new Error('Cab with this number already exists');
      }
      throw error;
    }
  }

  static async update(id, cabData) {
    try {
      const pool = getPool();
      const request = pool.request().input('id', sql.Int, id);
      
      const updates = [];
      
      if (cabData.cab_number) {
        request.input('cab_number', sql.NVarChar(50), cabData.cab_number);
        updates.push('cab_number = @cab_number');
      }
      if (cabData.capacity) {
        request.input('capacity', sql.Int, cabData.capacity);
        updates.push('capacity = @capacity');
      }
      if (cabData.driver_id !== undefined) {
        request.input('driver_id', sql.Int, cabData.driver_id);
        updates.push('driver_id = @driver_id');
      }
      if (cabData.status) {
        request.input('status', sql.NVarChar(20), cabData.status);
        updates.push('status = @status');
      }
      if (cabData.is_active !== undefined) {
        request.input('is_active', sql.Bit, cabData.is_active);
        updates.push('is_active = @is_active');
      }
      
      updates.push('updated_at = GETDATE()');
      
      const result = await request.query(`
        UPDATE cabs 
        SET ${updates.join(', ')}
        OUTPUT INSERTED.*
        WHERE id = @id
      `);
      
      logger.info(`Cab updated: ${id}`);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error updating cab:', error);
      throw error;
    }
  }

  static async updateLocation(id, latitude, longitude) {
    try {
      const pool = getPool();
      
      const result = await pool.request()
        .input('id', sql.Int, id)
        .input('latitude', sql.Float, latitude)
        .input('longitude', sql.Float, longitude)
        .query(`
          UPDATE cabs 
          SET current_latitude = @latitude, 
              current_longitude = @longitude,
              last_location_update = GETDATE(),
              updated_at = GETDATE()
          OUTPUT INSERTED.*
          WHERE id = @id
        `);
      
      // Also log to tracking table
      await pool.request()
        .input('cab_id', sql.Int, id)
        .input('latitude', sql.Float, latitude)
        .input('longitude', sql.Float, longitude)
        .query(`
          INSERT INTO cab_tracking (cab_id, latitude, longitude, recorded_at)
          VALUES (@cab_id, @latitude, @longitude, GETDATE())
        `);
      
      return result.recordset[0];
    } catch (error) {
      logger.error('Error updating cab location:', error);
      throw error;
    }
  }

  static async updateStatus(id, status) {
    try {
      const pool = getPool();
      
      const result = await pool.request()
        .input('id', sql.Int, id)
        .input('status', sql.NVarChar(20), status)
        .query(`
          UPDATE cabs 
          SET status = @status, updated_at = GETDATE()
          OUTPUT INSERTED.*
          WHERE id = @id
        `);
      
      logger.info(`Cab ${id} status updated to ${status}`);
      return result.recordset[0];
    } catch (error) {
      logger.error('Error updating cab status:', error);
      throw error;
    }
  }

  static async delete(id) {
    try {
      const pool = getPool();
      
      // Check for active assignments
      const checkResult = await pool.request()
        .input('id', sql.Int, id)
        .query(`
          SELECT COUNT(*) as active_requests
          FROM cab_requests 
          WHERE cab_id = @id AND status IN ('PENDING', 'ASSIGNED', 'IN_PROGRESS')
        `);
      
      if (checkResult.recordset[0].active_requests > 0) {
        throw new Error('Cannot delete cab with active requests. Complete or cancel requests first.');
      }
      
      const result = await pool.request()
        .input('id', sql.Int, id)
        .query(`
          UPDATE cabs 
          SET is_active = 0, updated_at = GETDATE()
          OUTPUT INSERTED.id
          WHERE id = @id
        `);
      
      if (result.recordset.length === 0) {
        throw new Error('Cab not found');
      }
      
      logger.info(`Cab deactivated: ${id}`);
      return { success: true, id };
    } catch (error) {
      logger.error('Error deleting cab:', error);
      throw error;
    }
  }

  static async getLocationHistory(cabId, startDate, endDate) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('cab_id', sql.Int, cabId)
        .input('start_date', sql.DateTime, startDate)
        .input('end_date', sql.DateTime, endDate)
        .query(`
          SELECT latitude, longitude, recorded_at
          FROM cab_tracking
          WHERE cab_id = @cab_id 
            AND recorded_at BETWEEN @start_date AND @end_date
          ORDER BY recorded_at DESC
        `);
      return result.recordset;
    } catch (error) {
      logger.error('Error fetching location history:', error);
      throw error;
    }
  }

  static async findCabsOnRoute(routeId) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('route_id', sql.Int, routeId)
        .query(`
          SELECT DISTINCT c.*, u.name as driver_name, u.phone as driver_phone
          FROM cabs c
          INNER JOIN users u ON c.driver_id = u.id
          INNER JOIN cab_requests cr ON cr.cab_id = c.id
          WHERE cr.route_id = @route_id 
            AND cr.status IN ('ASSIGNED', 'IN_PROGRESS')
            AND c.is_active = 1
        `);
      return result.recordset;
    } catch (error) {
      logger.error('Error finding cabs on route:', error);
      throw error;
    }
  }

  static async getAvailableSeats(cabId, routeId, tripDate) {
    try {
      const pool = getPool();
      const result = await pool.request()
        .input('cab_id', sql.Int, cabId)
        .input('route_id', sql.Int, routeId)
        .input('trip_date', sql.Date, tripDate)
        .query(`
          SELECT c.capacity - COALESCE(COUNT(cr.id), 0) as available_seats
          FROM cabs c
          LEFT JOIN cab_requests cr ON cr.cab_id = c.id 
            AND cr.route_id = @route_id
            AND CAST(cr.pickup_time AS DATE) = @trip_date
            AND cr.status IN ('ASSIGNED', 'IN_PROGRESS')
          WHERE c.id = @cab_id
          GROUP BY c.capacity
        `);
      return result.recordset[0]?.available_seats || 0;
    } catch (error) {
      logger.error('Error getting available seats:', error);
      throw error;
    }
  }
}

module.exports = Cab;
